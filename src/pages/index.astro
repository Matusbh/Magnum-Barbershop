---
/* Página de inicio: ensambla todos los componentes */
import Layout   from '../layouts/Layout.astro';
import Navbar   from '../components/Navbar.astro';
import Hero     from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Galeria  from '../components/Galeria.astro';
import Equipo   from '../components/Equipo.astro';
import Ubicacion from '../components/Ubicacion.astro';
import Reserva  from '../components/Reserva.astro';
import Resenas  from '../components/Resenas.astro';
import Contacto from '../components/Contacto.astro';
---

<Layout titulo="Magnum Barbershop & Tattoo · Puerto de la Cruz, Tenerife">
  <Navbar />
  <main>
    <Hero />
    <Servicios />
    <Galeria />
    <Equipo />
    <Ubicacion />
    <Resenas />
    <Reserva />
  </main>
  <Contacto />
</Layout>
