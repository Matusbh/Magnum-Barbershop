---
/* Sección de servicios: dos columnas Barbería / Tattoo con cards liquid glass */
import { Scissors, Pen } from '@lucide/astro';

const serviciosBarberia = [
  'Corte clásico con navaja',
  'Degradado y fade',
  'Arreglo de barba',
  'Afeitado con toalla caliente',
  'Diseño de perfil',
  'Tratamiento de cuero cabelludo',
];

const serviciosTattoo = [
  'Tatuaje realismo y blackwork',
  'Diseño personalizado',
  'Microrealism',
  'Coverup y restauración',
  'Fine line y dotwork',
  'Consultoría de diseño gratuita',
];
---

<section id="servicios" class="relative py-24 px-4 overflow-hidden">

  <!-- Textura de fondo con gradiente sutil -->
  <div class="absolute inset-0 bg-gradient-to-b from-fondo via-grisOscuro to-fondo opacity-80"></div>

  <!-- Glow de fondo izquierdo -->
  <div class="absolute -left-20 top-1/2 w-60 h-60 rounded-full bg-rojo/10 blur-[80px] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto">

    <!-- Título de sección -->
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl sm:text-4xl text-blanco mb-4 drop-shadow-[0_0_20px_rgba(255,31,31,0.4)]">
        SERVICIOS
      </h2>
      <div class="w-12 h-px bg-rojo mx-auto shadow-neonRojoSutil"></div>
    </div>

    <!-- Grid dos columnas -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Card Barbería -->
      <div class="liquid-glass rounded-xl p-8 group hover:border-rojo/30 transition-all duration-400">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-rojo/10 flex items-center justify-center group-hover:bg-rojo/20 transition-colors">
            <Scissors size={20} class="text-rojo" />
          </div>
          <h3 class="font-display text-xl text-blanco tracking-wide">Barbería</h3>
        </div>
        <ul class="space-y-3">
          {serviciosBarberia.map((servicio) => (
            <li class="flex items-start gap-3 text-blanco/70 text-sm leading-relaxed">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-rojo flex-shrink-0 shadow-neonRojoSutil"></span>
              {servicio}
            </li>
          ))}
        </ul>
      </div>

      <!-- Card Tattoo -->
      <div class="liquid-glass rounded-xl p-8 group hover:border-rojo/30 transition-all duration-400">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-rojo/10 flex items-center justify-center group-hover:bg-rojo/20 transition-colors">
            <Pen size={20} class="text-rojo" />
          </div>
          <h3 class="font-display text-xl text-blanco tracking-wide">Tattoo</h3>
        </div>
        <ul class="space-y-3">
          {serviciosTattoo.map((servicio) => (
            <li class="flex items-start gap-3 text-blanco/70 text-sm leading-relaxed">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-rojo flex-shrink-0 shadow-neonRojoSutil"></span>
              {servicio}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
